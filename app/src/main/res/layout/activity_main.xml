<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- FIRST SCREEN -->
        <LinearLayout
            android:id="@+id/homeScreen"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="RFID Stock Box"
                android:textSize="22sp"
                android:textStyle="bold"
                android:paddingBottom="16dp" />

            <TextView
                android:id="@+id/tvConnectedDevice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Connected Device: Not connected"
                android:textSize="17sp"
                android:textStyle="bold"
                android:paddingBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="16dp">

                <Button
                    android:id="@+id/btnConnectReader"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Connect Reader" />

                <Button
                    android:id="@+id/btnDisconnectReader"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="Stop Connect" />
            </LinearLayout>

            <EditText
                android:id="@+id/etSearchStockBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Search stock box"
                android:singleLine="true"
                android:padding="12dp"
                android:background="@android:drawable/edit_text"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btnStartScanPage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Start Scan"
                android:enabled="false"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/tvSelectedStockBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Selected Stock Box: None"
                android:textStyle="bold"
                android:textSize="16sp"
                android:paddingBottom="10dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Stock Box List"
                android:textStyle="bold"
                android:textSize="18sp"
                android:paddingBottom="8dp" />

            <LinearLayout
                android:id="@+id/stockBoxResultContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </LinearLayout>

        <!-- SECOND SCREEN -->
        <LinearLayout
            android:id="@+id/scanScreen"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvScanStockBoxName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Stock Box: -"
                android:textSize="21sp"
                android:textStyle="bold"
                android:paddingBottom="12dp" />

            <TextView
                android:id="@+id/tvDbTotalCount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="DB Total Count: 0"
                android:textSize="18sp"
                android:textStyle="bold"
                android:paddingBottom="8dp" />

            <TextView
                android:id="@+id/tvScannedEpcCount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Scanned EPC Count: 0"
                android:textSize="18sp"
                android:textStyle="bold"
                android:paddingBottom="12dp" />

            <TextView
                android:id="@+id/tvMatchedCount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="✅ Matched: 0"
                android:textSize="18sp"
                android:textStyle="bold"
                android:paddingBottom="6dp" />

            <TextView
                android:id="@+id/tvMissingCount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="❌ Missing: 0"
                android:textSize="18sp"
                android:textStyle="bold"
                android:paddingBottom="6dp" />

            <TextView
                android:id="@+id/tvExtraCount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="❌ Extra: 0"
                android:textSize="18sp"
                android:textStyle="bold"
                android:paddingBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="10dp">

                <Button
                    android:id="@+id/btnStartReadTags"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Start Read" />

                <Button
                    android:id="@+id/btnStopReadTags"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="Stop Read" />
            </LinearLayout>

            <Button
                android:id="@+id/btnClearEpcList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Clear EPC List"
                android:layout_marginBottom="10dp" />

            <Button
                android:id="@+id/btnBackHome"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Back"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Scanned EPC List"
                android:textSize="18sp"
                android:textStyle="bold"
                android:paddingBottom="8dp" />

            <TextView
                android:id="@+id/tvEpcList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No EPC scanned yet"
                android:textSize="15sp"
                android:padding="12dp"
                android:background="#EEEEEE" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>