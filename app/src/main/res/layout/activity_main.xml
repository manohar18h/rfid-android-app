<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- FIRST SCREEN -->
    <ScrollView
        android:id="@+id/homeScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="RFID Stock Box Scanner"
                android:textSize="22sp"
                android:textStyle="bold"
                android:paddingBottom="16dp" />

            <TextView
                android:id="@+id/tvConnectedDevice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Connected Reader: Not connected"
                android:textSize="17sp"
                android:textStyle="bold"
                android:paddingBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="16dp">

                <Button
                    android:id="@+id/btnConnectReader"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Connect Reader" />

                <Button
                    android:id="@+id/btnStopConnectReader"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="Stop Connect" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Search Stock Box"
                android:textSize="16sp"
                android:textStyle="bold"
                android:paddingBottom="6dp" />

            <EditText
                android:id="@+id/etSearchBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Type stock box name..."
                android:singleLine="true"
                android:padding="12dp"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btnLoadStockBoxes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Stock Box List"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvSelectedStockBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Selected Stock Box: None"
                android:textSize="16sp"
                android:textStyle="bold"
                android:paddingBottom="8dp" />

            <Button
                android:id="@+id/btnStartScanScreen"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Start Scan"
                android:enabled="false"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:id="@+id/stockBoxResultContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </LinearLayout>
    </ScrollView>

    <!-- SECOND SCREEN -->
    <ScrollView
        android:id="@+id/scanScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <Button
                android:id="@+id/btnBackHome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Back" />

            <TextView
                android:id="@+id/tvScanStockBoxName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Stock Box: -"
                android:textSize="20sp"
                android:textStyle="bold"
                android:paddingTop="12dp"
                android:paddingBottom="8dp" />

            <TextView
                android:id="@+id/tvDbTotalCount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="DB Total Count: 0"
                android:textSize="18sp"
                android:textStyle="bold"
                android:paddingBottom="8dp" />

            <TextView
                android:id="@+id/tvScannedEpcCount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Scanned EPC Count: 0"
                android:textSize="18sp"
                android:textStyle="bold"
                android:paddingBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="12dp">

                <Button
                    android:id="@+id/btnStartRead"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Start Read" />

                <Button
                    android:id="@+id/btnStopRead"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="Stop Read" />
            </LinearLayout>

            <Button
                android:id="@+id/btnClearEpcList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Clear EPC List"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Scanned EPC List"
                android:textSize="18sp"
                android:textStyle="bold"
                android:paddingBottom="8dp" />

            <TextView
                android:id="@+id/tvEpcList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No EPC scanned yet"
                android:textSize="15sp"
                android:padding="12dp"
                android:background="#EEEEEE" />

        </LinearLayout>
    </ScrollView>

</FrameLayout>